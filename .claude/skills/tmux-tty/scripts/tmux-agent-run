#!/usr/bin/env bash
set -euo pipefail

SESSION="claude-agents"
WINDOW=""
TIMEOUT=30
WAIT_FOR=""
SEND_ONLY=false

usage() {
  cat <<'USAGE'
Usage: tmux-agent-run [--session NAME] [--window NAME] [--timeout SECS] [--wait-for PATTERN] [--send-only] COMMAND...

  --session NAME     Tmux session name (default: claude-agents)
  --window NAME      Window name in <tool>:<context> format (required)
  --timeout SECS     Max seconds to wait for output (default: 30)
  --wait-for PATTERN ERE regex to wait for instead of sentinel
  --send-only        Send keys without waiting for output
USAGE
  exit 2
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --session)  SESSION="$2"; shift 2 ;;
    --window)   WINDOW="$2"; shift 2 ;;
    --timeout)  TIMEOUT="$2"; shift 2 ;;
    --wait-for) WAIT_FOR="$2"; shift 2 ;;
    --send-only) SEND_ONLY=true; shift ;;
    --help|-h)  usage ;;
    --)         shift; break ;;
    -*)         echo "Unknown flag: $1" >&2; usage ;;
    *)          break ;;
  esac
done

if [[ -z "$WINDOW" ]]; then
  echo "Error: --window is required" >&2
  usage
fi

if [[ $# -eq 0 ]]; then
  echo "Error: COMMAND is required" >&2
  usage
fi

COMMAND="$*"

# --- Session & Window Management ---

ensure_session() {
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux new-session -d -s "$SESSION"
  fi
}

# Returns 0 if window was created (new), 1 if it already existed (reuse)
ensure_window() {
  if tmux list-windows -t "$SESSION" -F '#{window_name}' | grep -qxF "$WINDOW"; then
    return 1  # exists, reuse
  else
    tmux new-window -t "$SESSION" -n "$WINDOW"
    return 0  # newly created
  fi
}

# Use '=' prefix for exact window name matching (avoids issues with colons in window names)
TARGET="$SESSION:=$WINDOW"

ensure_session
if ensure_window; then
  WINDOW_CREATED=true
else
  WINDOW_CREATED=false
fi

# --- Execution Modes ---

SENTINEL_ID="$(uuidgen 2>/dev/null || cat /proc/sys/kernel/random/uuid 2>/dev/null || echo $$-$RANDOM)"
SENTINEL="__AGENT_DONE_${SENTINEL_ID}"
START_MARKER="__AGENT_START_${SENTINEL_ID}__"

# Max iterations: TIMEOUT / 0.3, computed as integer (rounded up)
MAX_ITERS=$(( (TIMEOUT * 10 + 2) / 3 ))

capture_pane() {
  tmux capture-pane -t "$TARGET" -p -S -
}

# Extract output between START_MARKER and SENTINEL, parse exit code
extract_output() {
  local captured="$1"
  # Get lines between the actual echoed start marker (standalone line) and the
  # sentinel with exit code. We anchor patterns to avoid matching the raw typed
  # command lines that also contain these strings.
  echo "$captured" | sed -n "/^${START_MARKER}$/,/${SENTINEL}_[0-9]*__/{/^${START_MARKER}$/d;/${SENTINEL}_[0-9]*__/d;p;}"
}

parse_exit_code() {
  local captured="$1"
  # Extract the number between the final _ and __ in the sentinel line
  echo "$captured" | grep -oE "${SENTINEL}_[0-9]+__" | head -1 | sed "s/.*_\([0-9]*\)__/\1/"
}

poll_for_sentinel() {
  local i=0
  while (( i < MAX_ITERS )); do
    local captured
    captured="$(capture_pane)"
    if echo "$captured" | grep -qE "${SENTINEL}_[0-9]+__"; then
      extract_output "$captured"
      local ec
      ec="$(parse_exit_code "$captured")"
      return "${ec:-0}"
    fi
    sleep 0.3
    (( i++ ))
  done
  # Timeout — print what we have to stdout (per spec)
  capture_pane
  return 1
}

if [[ "$SEND_ONLY" == true ]]; then
  # Send-only mode: send keys and exit immediately
  tmux send-keys -t "$TARGET" -- "$COMMAND" Enter
  exit 0
fi

if [[ -n "$WAIT_FOR" ]]; then
  # Wait-for mode: send command, poll for pattern
  tmux send-keys -t "$TARGET" -- "$COMMAND" Enter
  i=0
  while (( i < MAX_ITERS )); do
    captured="$(capture_pane)"
    if echo "$captured" | grep -qE "$WAIT_FOR"; then
      echo "$captured"
      exit 0
    fi
    sleep 0.3
    (( i++ ))
  done
  # Timeout — print what we have to stdout (per spec)
  capture_pane
  exit 1
fi

# Normal sentinel mode: emit start marker, then wrapped command with sentinel
tmux send-keys -t "$TARGET" -- "echo ${START_MARKER}" Enter
WRAPPED="{ ${COMMAND} ; }; __ec=\$?; echo ${SENTINEL}_\${__ec}__"
tmux send-keys -t "$TARGET" -- "$WRAPPED" Enter
poll_for_sentinel
exit $?
